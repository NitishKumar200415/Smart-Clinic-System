# ─── QUICK CURL SEQUENCE ─────────────────────────────────────────────
#
#  # 1. Create patient
#  curl -s -X POST http://localhost:8080/api/patients \
#       -H "Content-Type: application/json" \
#       -d '{"name":"Aarav Mehta","phone":"+919876543210"}' | jq
#
#  # 2. Create doctor
#  curl -s -X POST http://localhost:8080/api/doctors \
#       -H "Content-Type: application/json" \
#       -d '{"name":"Dr. Priya Sharma","email":"priya@clinic.in"}' | jq
#
#  # 3. Create prescription
#  curl -s -X POST http://localhost:8080/api/prescriptions \
#       -H "Content-Type: application/json" \
#       -d '{
#             "patientId":1,"doctorId":1,
#             "diagnosis":"Acute Pharyngitis",
#             "medications":[
#               {"name":"Amoxicillin","dosage":"500mg","frequency":"Twice daily","duration":"7 days"}
#             ]
#           }' | jq
#
#  # 4. Fetch patient prescriptions
#  curl -s http://localhost:8080/api/prescriptions/patient/1 | jq
#
# ─────────────────────────────────────────────────────────────────────
